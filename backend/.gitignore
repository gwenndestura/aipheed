# Virtual environment
venv/

# Python cache
__pycache__/
*.pyc
*.pyo

# Environment variables
.env

# Model files — never commit
models/
*.pkl

# Raw data — never commit
data/raw/

# Processed parquets — derived from raw, reproducible via run_primary_data_collection.py
# Track only the manifest, ignore the parquets
data/processed/*.parquet
!data/processed/PRIMARY_DATA_MANIFEST.md

# Reference CSVs (full 142-LGU table, SAE 2021) — gitignored if added
data/reference/

# Eval outputs — regenerated each run
data/eval/*.json


# MLflow
mlruns/

# VS Code
.vscode/

# pytest cache
.pytest_cache/

# mypy cache
.mypy_cache/

# ruff cache
.ruff_cache/

# Distribution
dist/
build/
*.egg-info/

.claude/